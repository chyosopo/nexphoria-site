/* ── shared product mini-card ────────────────────────────────── */
function ProductMiniCard({
  slug,
  name,
  price,
  bullets,
  edge,
}: {
  slug: string;
  name: string;
  price: string;
  bullets: string[];
  edge: string;
}) {
  return (
    <div
      className="bg-white rounded-2xl border p-6"
      style={{ borderColor: edge }}
      data-testid={`product-card-${slug}`}
    >
      <div className="flex items-start justify-between mb-3">
        <h3
          className="text-xl"
          style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: "var(--nx-fg)" }}
        >
          {name}
        </h3>
        <span className="text-xs font-mono text-[var(--nx-fg-muted)] whitespace-nowrap mt-1">
          Starting at {price}
        </span>
      </div>
      <ul className="space-y-1.5 mb-5">
        {bullets.map((b) => (
          <li key={b} className="flex items-start gap-2 text-sm text-[var(--nx-fg-graphite)] leading-snug" style={{ fontFamily: "'Inter', sans-serif" }}>
            <span className="mt-1.5 w-1 h-1 rounded-full shrink-0" style={{ backgroundColor: INK }} aria-hidden />
            {b}
          </li>
        ))}
      </ul>
      <Link
        href={`/peptides/${slug}`}
        className="inline-flex items-center gap-1.5 text-sm font-medium transition-all hover:gap-2.5"
        style={{ color: INK }}
        data-testid={`product-link-${slug}`}
      >
        Start intake
        <ArrowRight size={14} />
      </Link>
    </div>
  );
}

/* ════════════════════════════════════════════════════════════════
   10 · DOCTOR LINEUP — cream. 5 cards, initials avatars, horizontal scroll.
   ════════════════════════════════════════════════════════════════ */
const DOCTORS = [
  { name: "Dr. Sarah Chen, MD", spec: "Internal Medicine", inst: "Yale", cert: "ABIM" },
  { name: "Dr. Marcus Torres, MD", spec: "Endocrinology", inst: "Mt. Sinai", cert: "ABIM-ENDO" },
  { name: "Dr. Aliyah Park, MD", spec: "Anti-Aging", inst: "Cleveland Clinic", cert: "ABFM" },
  { name: "Dr. Daniel Ross, MD", spec: "Sports Medicine", inst: "Stanford", cert: "ABOMS" },
  { name: "Dr. Elena Vasquez, MD", spec: "Functional Medicine", inst: "Harvard", cert: "ABFM" },
];

function initials(name: string) {
  const parts = name.replace(/Dr\.\s*/, "").replace(/,.*/, "").split(" ");
  return (parts[0]?.[0] ?? "") + (parts[1]?.[0] ?? "");
}

function DoctorLineup() {
  return (
    <section style={{ backgroundColor: CREAM }} data-testid="section-doctors">
      <div className="nx-container py-12 md:py-20">
        <div className="text-center mb-10 max-w-[44ch] mx-auto">
          <p className="nx-eyebrow mb-4">Designed by licensed physicians</p>
          <h2
            className="text-3xl md:text-4xl"
            style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: "var(--nx-fg)", lineHeight: 1.08, letterSpacing: "-0.02em" }}
          >
            Reviewed by board-certified U.S. doctors.
          </h2>
        </div>

        <div className="flex md:grid md:grid-cols-5 gap-4 overflow-x-auto md:overflow-visible pb-2 -mx-6 px-6 md:mx-0 md:px-0">
          {DOCTORS.map((d) => (
            <div
              key={d.name}
              className="bg-white rounded-2xl border border-[var(--nx-border)] p-6 text-center shrink-0 w-[200px] md:w-auto"
              data-testid={`doctor-${initials(d.name).toLowerCase()}`}
            >
              <div
                className="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-[var(--nx-bg)]"
                style={{ backgroundColor: INK, fontFamily: "'Fraunces', Georgia, serif", fontSize: "1.25rem", fontWeight: 500 }}
              >
                {initials(d.name)}
              </div>
              <p className="font-medium text-[var(--nx-fg)] text-sm leading-tight mb-1">{d.name}</p>
              <p className="text-xs text-[var(--nx-fg-graphite)]">{d.spec}</p>
              <p className="text-xs text-[var(--nx-fg-muted)] mt-0.5">{d.inst}</p>
              <p className="font-mono text-[9px] uppercase tracking-[0.12em] text-[var(--nx-fg-muted)] mt-2">
                Board cert: {d.cert}
              </p>
            </div>
          ))}
        </div>

        {/* Carousel indicator — page dots (non-functional this pass) */}
        <div className="flex items-center justify-center gap-2 mt-8" data-testid="doctor-carousel-dots">
          <span className="w-2 h-2 rounded-full" style={{ backgroundColor: INK }} aria-hidden />
          <span className="w-2 h-2 rounded-full" style={{ backgroundColor: "var(--nx-border)" }} aria-hidden />
          <span className="w-2 h-2 rounded-full" style={{ backgroundColor: "var(--nx-border)" }} aria-hidden />
          <span className="ml-2 font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--nx-fg-muted)]">
            1 of 2 pages →
          </span>
        </div>
      </div>
    </section>
  );
}

