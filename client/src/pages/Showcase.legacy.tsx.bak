            <p className="font-medium text-[var(--nx-fg)] mb-4 text-sm">
              How fast do you want to lose weight?
            </p>
            <div className="space-y-2.5">
              {[
                { id: "gentle", label: "Gentle — steady & sustainable" },
                { id: "steady", label: "Standard — most patients" },
                { id: "fast", label: "Aggressive — physician-managed" },
              ].map((opt) => (
                <button
                  key={opt.id}
                  type="button"
                  onClick={() => setGoal(opt.id)}
                  className="w-full flex items-center gap-3 rounded-lg border px-4 py-3 text-left transition-colors"
                  style={{
                    borderColor: goal === opt.id ? INK : "var(--nx-peach-edge)",
                    backgroundColor: goal === opt.id ? "var(--nx-bg)" : "transparent",
                  }}
                  data-testid={`metabolic-radio-${opt.id}`}
                >
                  <span
                    className="w-4 h-4 rounded-full border-2 shrink-0 flex items-center justify-center"
                    style={{ borderColor: goal === opt.id ? INK : "var(--nx-peach-edge)" }}
                  >
                    {goal === opt.id && (
                      <span className="w-2 h-2 rounded-full" style={{ backgroundColor: INK }} />
                    )}
                  </span>
                  <span className="text-sm text-[var(--nx-fg)]">{opt.label}</span>
                </button>
              ))}
            </div>
          </div>

          {/* Middle — 2 product cards */}
          <div className="space-y-5">
            {cards.map((c) => (
              <ProductMiniCard key={c.slug} {...c} edge="var(--nx-peach-edge)" />
            ))}
          </div>

          {/* Right — stat panel + chart */}
          <div className="rounded-2xl p-6 text-[var(--nx-bg)]" style={{ backgroundColor: INK }} data-testid="metabolic-stat">
            <p className="nx-eyebrow mb-4" style={{ color: "rgba(250,247,240,0.6)" }}>
              SURMOUNT-program median
            </p>
            <p
              className="text-3xl md:text-4xl mb-1"
              style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, lineHeight: 1.05 }}
            >
              14% bodyweight loss
            </p>
            <p className="text-xs mb-7" style={{ color: "rgba(250,247,240,0.65)" }}>
              median reduction over 12 weeks
            </p>
            <BarChart values={[0, 4, 9, 14]} labels={["0w", "4w", "8w", "12w"]} max={16} accent="var(--nx-rust)" />
          </div>
        </div>
      </div>
    </section>
  );
}

