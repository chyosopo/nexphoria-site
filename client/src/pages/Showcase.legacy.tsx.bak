  return (
    <section style={{ backgroundColor: "var(--nx-peach)" }} data-testid="section-metabolic">
      <div className="nx-container py-12 md:py-20">
        <div className="mb-8 md:mb-11 max-w-[40ch]">
          <p
            className="text-base mb-2"
            style={{ fontFamily: "'Fraunces', Georgia, serif", fontStyle: "italic", color: INK }}
          >
