/* ──────────────────────────────────────────────────────────────
   Showcase — Maximus-structural homepage.
   Paneled / tiled layout: pastel blocks rotate (cream → ice → peach →
   sage → cobalt), each with a left text column + right visual/data
   column. Dense, geometric, no photographic imagery.
   13 sections in scroll order. Composition mirrors maximustribe.com.
   ────────────────────────────────────────────────────────────── */

import { useState } from "react";
import { Link } from "wouter";
import { SiteLayout } from "@/components/SiteLayout";
import { MolecularGlyph } from "@/components/MolecularGlyph";
import { FAQAccordion } from "@/components/FAQAccordion";
import { AnimatedCounter } from "@/components/AnimatedCounter";
import { peptides, CATEGORY_LABELS, type PeptideCategory } from "@/data/peptides";
import {
  ArrowRight,
  ArrowUpRight,
  Check,
  ShieldCheck,
  Syringe,
  Snowflake,
  FlaskConical,
  Pill,
  Droplet,
  BadgeCheck,
} from "lucide-react";

/* ── helpers ─────────────────────────────────────────────────── */
const INK = "var(--nx-cobalt)"; // #0A0A0A — the dark "cobalt" panel ink
const CREAM = "var(--nx-bg)";

export default function Showcase() {
  return (
    <SiteLayout navVariant="showcase">
      <HeroSection />
      <SecondaryTrustBand />
      <CobaltTrustBar />
      <HowItWorksStrip />
      <CategoryTileGrid />
      <OutcomeStatsStrip />
      <ProtocolHeroPanel />
      <ProofRow />
      <MetabolicDeepDive />
      <RecoveryDeepDive />
      <DoctorLineup />
      <PatientJournalsBand />
      <FAQAccordion title="Common questions." items={HOME_FAQS} />
      <CobaltCloser />
    </SiteLayout>
  );
}

/* ════════════════════════════════════════════════════════════════
   3 · HERO — H1 + italic accent left (~60%), credential pills right
   ════════════════════════════════════════════════════════════════ */
/* Inline KPI strip — 4 stat tiles between subhead and CTAs (task 2) */
const HERO_KPIS: { value?: number; suffix?: string; staticLabel?: string; label: string }[] = [
  { value: 17, label: "PEPTIDES" },
  { value: 3200, suffix: "+", label: "PATIENTS" },
  { staticLabel: "U.S.", label: "PHYSICIAN-REVIEWED" },
  { staticLabel: "USP <797>", label: "COMPOUNDED" },
];

/* Condensed TODAY'S PROTOCOLS rows (task 6) */
const TODAY_PROTOCOLS = [
  { slug: "tirzepatide", name: "Tirzepatide", dose: "2.5mg" },
  { slug: "bpc-157", name: "BPC-157", dose: "250mcg" },
  { slug: "nad-plus", name: "NAD+", dose: "100mg" },
];

function HeroSection() {
  return (
    <section
      className="border-b border-[var(--nx-border)]"
      style={{ backgroundColor: CREAM }}
      data-testid="section-hero"
    >
      {/* Top padding tightened: ~80px from nav instead of ~150px (task 1) */}
      <div className="nx-container pt-10 md:pt-12 pb-12 md:pb-16">
        {/* 60/40 split (task 5) */}
        <div className="grid lg:grid-cols-[1.5fr_1fr] gap-10 lg:gap-14 items-start">
          {/* Left 60% — eyebrow, headline, subhead, KPI strip, CTAs */}
          <div>
            <p className="nx-eyebrow mb-4" data-testid="hero-eyebrow">
              ● Peptide pharmacy · Physician-prescribed
            </p>
            <h1 className="nx-hero-heading mb-5 max-w-[16ch]" data-testid="hero-headline">
              Every peptide.{" "}
              <span className="nx-italic-accent">With prescription.</span>
            </h1>
            <p
              className="text-lg md:text-xl text-[var(--nx-fg-graphite)] max-w-[48ch] leading-relaxed"
              data-testid="hero-sub"
            >
              Seventeen compounds across seven categories. Each one prescribed by
              a licensed U.S. physician, compounded at a USP&nbsp;&lt;797&gt;
              pharmacy, and shipped cold-chain to your door.
            </p>

            {/* Inline KPI strip (task 2) — DM Mono labels, large number, hairline dividers */}
            <div
              className="mt-7 grid grid-cols-2 sm:grid-cols-4 border-y border-[var(--nx-border)]"
              data-testid="hero-kpi-strip"
            >
              {HERO_KPIS.map((k, i) => (
                <div
                  key={k.label}
                  className={`py-4 sm:py-5 border-[var(--nx-border)] ${i > 0 ? "sm:border-l sm:pl-5" : ""} ${i % 2 === 1 ? "border-l pl-5" : ""} ${i >= 2 ? "border-t sm:border-t-0" : ""}`}
                  data-testid={`hero-kpi-${i}`}
                >
                  <div
                    className="text-2xl md:text-[1.7rem] leading-none mb-1.5 tabular"
                    style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: INK }}
                  >
                    {k.value !== undefined ? (
                      <AnimatedCounter value={k.value} suffix={k.suffix ?? ""} />
                    ) : (
                      k.staticLabel
                    )}
                  </div>
                  <div className="font-mono text-[9px] md:text-[10px] uppercase tracking-[0.14em] text-[var(--nx-fg-muted)] leading-tight">
                    {k.label}
                  </div>
                </div>
              ))}
            </div>

            <div className="mt-7 flex flex-wrap gap-3">
              <Link
                href="/peptides"
                className="nx-cta-cobalt inline-flex items-center gap-2"
                data-testid="hero-cta-browse"
              >
                Browse the pharmacy
                <ArrowRight size={16} />
              </Link>
              <Link
                href="/assessment"
                className="nx-cta-ghost inline-flex items-center gap-2"
                data-testid="hero-cta-intake"
              >
                Start intake
              </Link>
            </div>
          </div>

          {/* Right 40% — credential card stack + TODAY'S PROTOCOLS */}
          <div className="lg:border-l lg:border-[var(--nx-border)] lg:pl-8">
            <p className="nx-eyebrow mb-4 text-[var(--nx-fg-muted)]">
              What backs every order
            </p>
            {/* Tightened card spacing (task 5) + 4th GUARANTEE card */}
            <ul className="space-y-2">
              {[
                { icon: ShieldCheck, label: "USP <797> compounding", sub: "Sterile 503A facility" },
                { icon: FlaskConical, label: "Rx required", sub: "Physician review before dispense" },
                { icon: Snowflake, label: "Cold-chain shipped", sub: "Refrigerated 2-day delivery" },
                { icon: BadgeCheck, label: "Guarantee", sub: "Refund if no protocol fit" },
              ].map((pill) => {
                const Icon = pill.icon;
                return (
                  <li
                    key={pill.label}
                    className="flex items-center gap-3.5 bg-white border border-[var(--nx-border)] rounded-xl px-3.5 py-3"
                    data-testid={`hero-pill-${pill.label.toLowerCase().replace(/[^a-z]+/g, "-")}`}
                  >
                    <span
                      className="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
                      style={{ backgroundColor: "var(--nx-ice)" }}
                    >
                      <Icon size={16} style={{ color: INK }} strokeWidth={1.7} />
                    </span>
                    <span>
                      <span className="block text-sm font-medium text-[var(--nx-fg)] leading-tight">
                        {pill.label}
                      </span>
                      <span className="block text-xs text-[var(--nx-fg-muted)] mt-0.5">
                        {pill.sub}
                      </span>
                    </span>
                  </li>
                );
              })}
            </ul>

            {/* TODAY'S PROTOCOLS condensed panel (task 6) */}
            <div
              className="mt-4 bg-white border border-[var(--nx-border)] rounded-xl p-3.5"
              data-testid="hero-today-protocols"
            >
              <p className="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--nx-fg-muted)] mb-2.5">
                Today&apos;s protocols
              </p>
              <ul className="space-y-0">
                {TODAY_PROTOCOLS.map((p, i) => (
                  <li key={p.slug}>
                    <Link
                      href={`/peptides/${p.slug}`}
                      className="flex items-center justify-between py-2 group"
                      style={{ borderTop: i > 0 ? "1px solid var(--nx-border)" : "none" }}
                      data-testid={`hero-protocol-${p.slug}`}
                    >
                      <span className="text-sm text-[var(--nx-fg)]">
                        <span className="font-medium">{p.name}</span>
                        <span className="text-[var(--nx-fg-muted)]"> · {p.dose}</span>
                      </span>
                      <ArrowUpRight
                        size={15}
                        style={{ color: INK }}
                        className="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                      />
                    </Link>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   3b · SECONDARY TRUST BAND — static dense band above marquee (task 3)
   ════════════════════════════════════════════════════════════════ */
function SecondaryTrustBand() {
  const items = [
    "FDA-registered facility",
    "USP <797> sterile",
    "503A pharmacy",
    "Cold-chain shipping",
    "15-min physician consult",
  ];
  return (
    <section
      style={{ backgroundColor: INK, color: CREAM }}
      data-testid="section-trust-static"
    >
      <div className="nx-container">
        <div className="grid grid-cols-2 md:grid-cols-5 divide-x divide-[rgba(250,247,240,0.12)] border-b border-[rgba(250,247,240,0.12)]">
          {items.map((it, i) => (
            <div
              key={it}
              className={`py-4 md:py-5 px-3 md:px-4 text-center border-[rgba(250,247,240,0.12)] ${i >= 2 ? "border-t md:border-t-0" : ""} ${i === 4 ? "col-span-2 md:col-span-1" : ""}`}
              data-testid={`trust-static-${i}`}
            >
              <span className="font-mono text-[10px] md:text-[11px] uppercase tracking-[0.12em]" style={{ color: "rgba(250,247,240,0.85)" }}>
                {it}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   3c · HOW IT WORKS IN 60 SECONDS — 4 numbered chips inline (task 4)
   ════════════════════════════════════════════════════════════════ */
function HowItWorksStrip() {
  const steps = [
    { n: "01", label: "Intake", time: "12 min" },
    { n: "02", label: "Bloodwork", time: "lab kit" },
    { n: "03", label: "Protocol", time: "24-48h" },
    { n: "04", label: "Cold-chain delivery", time: "2-day Rx" },
  ];
  return (
    <section style={{ backgroundColor: CREAM }} data-testid="section-how-it-works" className="border-b border-[var(--nx-border)]">
      <div className="nx-container py-7 md:py-9">
        <div className="flex items-center justify-between flex-wrap gap-3 mb-4">
          <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--nx-fg-muted)]">
            How it works in 60 seconds
          </p>
          <Link
            href="/how-it-works"
            className="inline-flex items-center gap-1.5 text-sm font-medium transition-all hover:gap-2.5"
            style={{ color: INK }}
            data-testid="how-it-works-link"
          >
            Full process
            <ArrowRight size={14} />
          </Link>
        </div>
        <div className="flex flex-wrap items-stretch gap-2.5 md:gap-3">
          {steps.map((s, i) => (
            <div key={s.n} className="flex items-center gap-2.5 md:gap-3 flex-1 min-w-[140px]">
              <div
                className="flex-1 flex items-center gap-3 bg-white border border-[var(--nx-border)] rounded-xl px-4 py-3"
                data-testid={`how-step-${s.n}`}
              >
                <span
                  className="shrink-0 font-mono text-[11px] tracking-[0.1em]"
                  style={{ color: "var(--nx-rust)" }}
                >
                  {s.n}
                </span>
                <span className="min-w-0">
                  <span className="block text-sm font-medium text-[var(--nx-fg)] leading-tight">
                    {s.label}
                  </span>
                  <span className="block font-mono text-[10px] uppercase tracking-[0.1em] text-[var(--nx-fg-muted)] mt-0.5">
                    {s.time}
                  </span>
                </span>
              </div>
              {i < steps.length - 1 && (
                <ArrowRight size={16} className="shrink-0 hidden md:block" style={{ color: "var(--nx-fg-muted)" }} />
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   4 · CATEGORY TILE GRID — 2 big tiles + 5 pill tiles. Flat pastels.
   ════════════════════════════════════════════════════════════════ */
interface Tile {
  category: PeptideCategory;
  title: string;
  desc: string;
  bg: string;
  glyph: Parameters<typeof MolecularGlyph>[0]["glyph"];
  price: string;
  badge?: string;
  count: number;
}

const BIG_TILES: Tile[] = [
  {
    category: "metabolic",
    title: "Metabolic & Weight",
    desc: "GLP-1 / GIP agonists. Appetite, glucose, body-composition.",
    bg: "var(--nx-ice)",
    glyph: "chain",
    price: "From $189/mo",
    badge: "MOST PRESCRIBED",
    count: 3,
  },
  {
    category: "recovery",
    title: "Recovery & Repair",
    desc: "Tissue-repair signals for tendon, ligament, gut, and soft tissue.",
    bg: "var(--nx-peach)",
    glyph: "helix",
    price: "From $149/mo",
    badge: "MOST PRESCRIBED",
    count: 2,
  },
];

const PILL_TILES: Tile[] = [
  { category: "longevity", title: "Longevity", desc: "Cellular age", bg: "var(--nx-sage)", glyph: "ring", price: "From $129/mo", badge: "POPULAR", count: 4 },
  { category: "skin", title: "Skin & Aesthetics", desc: "Collagen, hair", bg: "var(--nx-peach)", glyph: "copper", price: "From $99/mo", count: 1 },
  { category: "sleep", title: "Sleep", desc: "Slow-wave depth", bg: "var(--nx-ice)", glyph: "branch", price: "From $89/mo", count: 1 },
  { category: "cognition", title: "Cognition & Mood", desc: "Focus, calm", bg: "var(--nx-sage)", glyph: "fragment", price: "From $109/mo", badge: "NEW", count: 2 },
  { category: "growth", title: "Growth Hormone", desc: "GHRH peptides", bg: "var(--nx-ice)", glyph: "ghrh", price: "From $169/mo", count: 3 },
];

function CategoryTileGrid() {
  return (
    <section style={{ backgroundColor: CREAM }} data-testid="section-tiles">
      <div className="nx-container py-12 md:py-16">
        {/* Section header — updated eyebrow + view-all link */}
        <div className="flex items-end justify-between gap-4 mb-6 md:mb-8">
          <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--nx-fg-muted)]" data-testid="tiles-eyebrow">
            Updated June 2026
          </p>
          <Link
            href="/peptides"
            className="inline-flex items-center gap-1.5 text-sm font-medium transition-all hover:gap-2.5"
            style={{ color: INK }}
            data-testid="tiles-view-all"
          >
            View all 17 peptides
            <ArrowRight size={14} />
          </Link>
        </div>

        {/* Top row: 2 big tiles */}
        <div className="grid md:grid-cols-2 gap-4 md:gap-5 mb-4 md:mb-5">
          {BIG_TILES.map((t) => (
            <Link
              key={t.category}
              href={`/peptides?category=${t.category}`}
              className="nx-tile group relative block rounded-2xl p-7 md:p-9 min-h-[200px] md:min-h-[260px] overflow-hidden"
              style={{ backgroundColor: t.bg }}
              data-testid={`tile-big-${t.category}`}
            >
              <div className="absolute top-6 left-7 md:left-9 flex items-center gap-2">
                {t.badge && (
                  <span
                    className="font-mono text-[9px] uppercase tracking-[0.16em] px-2 py-1 rounded-full"
                    style={{ backgroundColor: INK, color: CREAM }}
                    data-testid={`tile-badge-${t.category}`}
                  >
                    {t.badge}
                  </span>
                )}
                <span
                  className="font-mono text-[9px] uppercase tracking-[0.14em] px-2 py-1 rounded-full border"
                  style={{ borderColor: INK, color: INK }}
                  data-testid={`tile-count-${t.category}`}
                >
                  {t.count} PEPTIDES
                </span>
              </div>
              <div className="absolute top-6 right-6 opacity-70" style={{ color: INK }}>
                <MolecularGlyph glyph={t.glyph} size={48} title={`${t.title} glyph`} />
              </div>
              <p className="nx-eyebrow mb-3 mt-7">Most requested</p>
              <h2
                className="text-2xl md:text-4xl mb-3 max-w-[12ch]"
                style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: "var(--nx-fg)", lineHeight: 1.05, letterSpacing: "-0.02em" }}
              >
                {t.title}
              </h2>
              <p className="text-sm md:text-base text-[var(--nx-fg-graphite)] max-w-[34ch] leading-relaxed">
                {t.desc}
              </p>
              <span
                className="absolute bottom-6 right-6 font-mono text-[11px] text-[var(--nx-fg-graphite)]"
                data-testid={`tile-price-${t.category}`}
              >
                {t.price}
              </span>
              <ArrowUpRight
                size={22}
                className="absolute bottom-6 left-7 md:left-9 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                style={{ color: INK }}
              />
            </Link>
          ))}
        </div>

        {/* Bottom row: 5 pill tiles */}
        <div className="grid grid-cols-2 md:grid-cols-5 gap-4 md:gap-5">
          {PILL_TILES.map((t) => (
            <Link
              key={t.category}
              href={`/peptides?category=${t.category}`}
              className="nx-tile group relative block rounded-2xl p-5 md:p-6 min-h-[150px] md:min-h-[176px] overflow-hidden"
              style={{ backgroundColor: t.bg }}
              data-testid={`tile-pill-${t.category}`}
            >
              <div className="absolute top-4 left-5 md:left-6 flex flex-wrap items-center gap-1.5">
                {t.badge && (
                  <span
                    className="font-mono text-[8px] uppercase tracking-[0.14em] px-1.5 py-0.5 rounded-full"
                    style={{ backgroundColor: INK, color: CREAM }}
                    data-testid={`tile-badge-${t.category}`}
                  >
                    {t.badge}
                  </span>
                )}
                <span
                  className="font-mono text-[8px] uppercase tracking-[0.12em] px-1.5 py-0.5 rounded-full border"
                  style={{ borderColor: INK, color: INK }}
                  data-testid={`tile-count-${t.category}`}
                >
                  {t.count} PEPTIDES
                </span>
              </div>
              <div className="absolute top-4 right-4 opacity-65" style={{ color: INK }}>
                <MolecularGlyph glyph={t.glyph} size={28} title={`${t.title} glyph`} />
              </div>
              <h3
                className={`text-base md:text-lg mb-1 max-w-[10ch] mt-5`}
                style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: "var(--nx-fg)", lineHeight: 1.1 }}
              >
                {t.title}
              </h3>
              <p className="text-xs text-[var(--nx-fg-graphite)]">{t.desc}</p>
              <span
                className="absolute bottom-4 right-4 font-mono text-[10px] text-[var(--nx-fg-graphite)]"
                data-testid={`tile-price-${t.category}`}
              >
                {t.price}
              </span>
              <ArrowUpRight
                size={16}
                className="absolute bottom-4 left-5 md:left-6 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                style={{ color: INK }}
              />
            </Link>
          ))}
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   5 · COBALT TRUST BAR — full-width dark, rotating credentials
   ════════════════════════════════════════════════════════════════ */
function CobaltTrustBar() {
  const items = [
    "17 peptides",
    "7 categories",
    "3,200+ patients",
    "USP <797> compounding",
    "Cold-chain delivery",
  ];
  // One pass of the row, with pipe separators. Rendered twice inside the
  // track so the loop reads seamlessly; the whole sequence repeats 2x.
  const Row = ({ keyPrefix }: { keyPrefix: string }) => (
    <span className="inline-flex items-center" aria-hidden={keyPrefix !== "a"}>
      {items.map((it, i) => (
        <span key={`${keyPrefix}-${i}`} className="inline-flex items-center">
          <span
            className="text-sm md:text-base px-5 md:px-7"
            style={{ fontFamily: "'Fraunces', Georgia, serif", fontStyle: "italic", color: CREAM }}
            data-testid={keyPrefix === "a" ? `trust-item-${i}` : undefined}
          >
            {it}
          </span>
          <span
            className="text-base md:text-lg select-none"
            style={{ fontFamily: "'Fraunces', Georgia, serif", fontStyle: "italic", color: "rgba(250,247,240,0.3)" }}
            aria-hidden
          >
            |
          </span>
        </span>
      ))}
    </span>
  );
  return (
    <section
      className="overflow-hidden"
      style={{ backgroundColor: INK, color: CREAM }}
      data-testid="section-trustbar"
    >
      <div className="py-5 md:py-6">
        {/* Marquee: track holds 2 identical sequences; animates -50% for a
            seamless loop. prefers-reduced-motion halts via CSS. */}
        <div className="nx-marquee-track">
          <Row keyPrefix="a" />
          <Row keyPrefix="b" />
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   6 · PROTOCOL HERO PANEL — ice. Left text + ghost CTA. Right molecule.
   ════════════════════════════════════════════════════════════════ */
function ProtocolHeroPanel() {
  const lineup: Parameters<typeof MolecularGlyph>[0]["glyph"][] = [
    "chain",
    "helix",
    "ring",
    "ghrh",
    "branch",
  ];
  return (
    <section style={{ backgroundColor: "var(--nx-ice)" }} data-testid="section-protocol-hero">
      <div className="nx-container py-12 md:py-20">
        <div className="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          {/* Left text */}
          <div>
            <p className="nx-eyebrow mb-5">The Nexphoria method</p>
            <h2
              className="text-3xl md:text-5xl mb-6 max-w-[16ch]"
              style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: "var(--nx-fg)", lineHeight: 1.04, letterSpacing: "-0.02em" }}
            >
              Sequencing{" "}
              <span style={{ fontStyle: "italic", color: INK }}>molecules</span>{" "}
              into protocols.
            </h2>
            <p className="text-lg text-[var(--nx-fg-graphite)] max-w-[44ch] leading-relaxed mb-8">
              Each peptide is a single instruction. A protocol is a sentence —
              compounds sequenced and timed by a physician toward one outcome.
            </p>
            <Link
              href="/stacks"
              className="nx-cta-ghost inline-flex items-center gap-2"
              data-testid="protocol-cta"
            >
              Browse protocols
              <ArrowRight size={16} />
            </Link>
          </div>

          {/* Right molecule abstraction — glyph lineup on a card */}
          <div className="relative">
            <div className="bg-white/70 rounded-3xl border border-[var(--nx-ice-edge)] p-8 md:p-10">
              <div className="flex items-center justify-between flex-wrap gap-4" style={{ color: INK }}>
                {lineup.map((g, i) => (
                  <div key={g + i} className="flex items-center gap-3 md:gap-4">
                    <MolecularGlyph glyph={g} size={64} title={`${g} molecule`} />
                    {i < lineup.length - 1 && (
                      <span className="h-px w-5 md:w-7 bg-[var(--nx-ice-edge)]" aria-hidden />
                    )}
                  </div>
                ))}
              </div>
              <div className="mt-7 pt-6 border-t border-[var(--nx-ice-edge)] flex items-center gap-2">
                <span className="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--nx-fg-muted)]">
                  peptide → receptor → signal → response
                </span>
              </div>
            </div>

            {/* 3-step protocol cadence — compact vertical stack */}
            <div className="mt-5 space-y-3" data-testid="protocol-steps">
              {[
                { n: "01", label: "Intake & bloodwork" },
                { n: "02", label: "Physician-tuned protocol" },
                { n: "03", label: "Quarterly recalibration" },
              ].map((s) => (
                <div
                  key={s.n}
                  className="flex items-baseline gap-3 pl-4"
                  style={{ borderLeft: "1px solid var(--nx-cobalt)" }}
                  data-testid={`protocol-step-${s.n}`}
                >
                  <span
                    className="shrink-0"
                    style={{ fontFamily: "'Fraunces', Georgia, serif", fontStyle: "italic", fontWeight: 500, color: INK, fontSize: "1.05rem" }}
                  >
                    {s.n}
                  </span>
                  <span className="text-sm text-[var(--nx-fg-graphite)]" style={{ fontFamily: "'Inter', sans-serif" }}>
                    — {s.label}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  );
}

/* ════════════════════════════════════════════════════════════════
   7 · 3-COLUMN PROOF ROW — formats · big stat + chart · checklist
   ════════════════════════════════════════════════════════════════ */
const PROOF_CHANGES = [
  { key: "appetite", label: "Appetite" },
  { key: "recovery", label: "Recovery" },
  { key: "sleep", label: "Sleep" },
  { key: "skin", label: "Skin" },
  { key: "cognition", label: "Cognition" },
  { key: "cellular-age", label: "Cellular age" },
];

function ProofRow() {
  const [selected, setSelected] = useState<Record<string, boolean>>({});
  const anySelected = Object.values(selected).some(Boolean);
  const toggle = (key: string) =>
    setSelected((prev) => ({ ...prev, [key]: !prev[key] }));
  return (
    <section className="bg-white border-y border-[var(--nx-border)]" data-testid="section-proof">
      <div className="nx-container py-12 md:py-16">
        <div className="grid md:grid-cols-3 gap-px bg-[var(--nx-border)] border border-[var(--nx-border)] rounded-2xl overflow-hidden">
          {/* Col 1 — Treatment formats */}
          <div className="bg-white p-7 md:p-8" data-testid="proof-formats">
            <p className="nx-eyebrow mb-5">Treatment formats</p>
            <ul className="space-y-4">
              {[
                { icon: Syringe, label: "Subcutaneous", sub: "Most peptides — small insulin needle" },
                { icon: Pill, label: "Oral troches", sub: "Dissolvable, for select compounds" },
                { icon: Droplet, label: "Topical cream", sub: "Compounded dermal formulations" },
              ].map((f) => {
                const Icon = f.icon;
                return (
                  <li key={f.label} className="flex items-start gap-3">
                    <Icon size={18} style={{ color: INK }} strokeWidth={1.7} className="mt-0.5 shrink-0" />
                    <span>
                      <span className="block font-medium text-[var(--nx-fg)] text-sm">{f.label}</span>
                      <span className="block text-xs text-[var(--nx-fg-muted)] mt-0.5">{f.sub}</span>
                    </span>
                  </li>
                );
              })}
            </ul>
          </div>

          {/* Col 2 — Patient outcomes: big stat + clinical chart */}
          <div className="bg-white p-7 md:p-8" data-testid="proof-outcomes">
            <p className="nx-eyebrow mb-5">Patient outcomes</p>
            <p
              className="text-5xl md:text-6xl mb-2"
              style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: INK, lineHeight: 1 }}
            >
              14%
            </p>
            <p className="text-sm text-[var(--nx-fg-graphite)] mb-6 max-w-[28ch]">
              median bodyweight reduction at 12 weeks on metabolic protocols
            </p>
            <ClinicalChart
              values={[0, 4, 9, 14]}
              valueLabels={["0", "4%", "9%", "14%"]}
              weekLabels={["0", "4", "8", "12"]}
              max={16}
            />
          </div>

          {/* Col 3 — What do you want to change? interactive checklist */}
          <div className="bg-white p-7 md:p-8" data-testid="proof-checklist">
            <p className="nx-eyebrow mb-5">What do you want to change?</p>
            <ul className="space-y-2.5">
              {PROOF_CHANGES.map((c) => {
                const on = !!selected[c.key];
                return (
                  <li key={c.key}>
                    <button
                      type="button"
                      onClick={() => toggle(c.key)}
                      aria-pressed={on}
                      className="w-full flex items-center gap-3 border rounded-lg px-3.5 py-2.5 text-left transition-colors"
                      style={{
                        borderColor: on ? INK : "var(--nx-border)",
                        backgroundColor: on ? "var(--nx-bg-cream)" : "transparent",
                      }}
                      data-testid={`checkbox-${c.key}`}
                    >
                      <span
                        className="w-5 h-5 rounded-[5px] flex items-center justify-center shrink-0 transition-colors"
                        style={{
                          backgroundColor: on ? INK : "transparent",
                          border: on ? `1px solid ${INK}` : "1.5px solid var(--nx-border)",
                        }}
                      >
                        {on && <Check size={12} style={{ color: CREAM }} strokeWidth={2.6} />}
                      </span>
                      <span className="text-sm text-[var(--nx-fg)]">{c.label}</span>
                    </button>
                  </li>
                );
              })}
            </ul>
            {anySelected && (
              <Link
                href="/assessment"
                className="mt-4 inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
                style={{ backgroundColor: INK, color: CREAM }}
                data-testid="proof-build-cta"
              >
                Build my protocol
                <ArrowRight size={14} />
              </Link>
            )}
          </div>
        </div>
      </div>
    </section>
  );
}

/* ── Shared CSS bar chart ────────────────────────────────────── */
function BarChart({
  values,
  labels,
  max,
  accent = INK,
}: {
  values: number[];
  labels: string[];
  max: number;
  accent?: string;
}) {
  return (
    <div className="flex items-end gap-3 h-32" data-testid="bar-chart">
      {values.map((v, i) => (
        <div key={i} className="flex-1 flex flex-col items-center justify-end gap-2 h-full">
          <span className="font-mono text-[11px] text-[var(--nx-fg-muted)]">{v}%</span>
          <div
            className="w-full rounded-t-md transition-all"
            style={{
              height: `${Math.max((v / max) * 100, 3)}%`,
              backgroundColor: i === values.length - 1 ? accent : "var(--nx-ice-edge)",
            }}
          />
          <span className="font-mono text-[10px] uppercase tracking-wider text-[var(--nx-fg-muted)]">
            {labels[i]}
          </span>
        </div>
      ))}
    </div>
  );
}

/* ── Clinical chart — measured: Y-axis label, value labels, week axis, baseline ── */
function ClinicalChart({
  values,
  valueLabels,
  weekLabels,
  max,
  accent = INK,
}: {
  values: number[];
  valueLabels: string[];
  weekLabels: string[];
  max: number;
  accent?: string;
}) {
  return (
    <div className="flex items-stretch gap-2" data-testid="clinical-chart">
      {/* Rotated Y-axis label */}
      <div className="flex items-center justify-center" style={{ width: "14px" }}>
        <span
          className="font-mono text-[9px] uppercase tracking-[0.12em] text-[var(--nx-fg-muted)] whitespace-nowrap"
          style={{ transform: "rotate(-90deg)" }}
        >
          % bodyweight reduction
        </span>
      </div>

      <div className="flex-1">
        {/* Bars + value labels, with hairline baseline */}
        <div
          className="flex items-end gap-3 h-32"
          style={{ borderBottom: "1px solid var(--nx-border)" }}
        >
          {values.map((v, i) => (
            <div key={i} className="flex-1 flex flex-col items-center justify-end gap-2 h-full">
              <span className="font-mono text-[11px] text-[var(--nx-fg-muted)]">{valueLabels[i]}</span>
              <div
                className="w-full rounded-t-md transition-all"
                style={{
                  height: `${Math.max((v / max) * 100, 2)}%`,
                  backgroundColor: i === values.length - 1 ? accent : "var(--nx-ice-edge)",
                }}
              />
            </div>
          ))}
        </div>
        {/* X-axis week labels */}
        <div className="flex gap-3 mt-1.5">
          {weekLabels.map((w, i) => (
            <span
              key={i}
              className="flex-1 text-center font-mono text-[10px] text-[var(--nx-fg-muted)]"
            >
              {w}
            </span>
          ))}
        </div>
        <p className="font-mono text-[9px] uppercase tracking-[0.14em] text-[var(--nx-fg-muted)] text-center mt-1">
          week
        </p>
      </div>
    </div>
  );
}

