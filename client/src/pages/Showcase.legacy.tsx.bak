          Outcomes on protocol · illustrative trial averages
        </p>
        <div className="grid grid-cols-2 lg:grid-cols-4 gap-px bg-[var(--nx-border)] border border-[var(--nx-border)] rounded-2xl overflow-hidden">
          {OUTCOME_STATS.map((o, i) => (
            <div key={o.label} className="bg-white p-5 md:p-7" data-testid={`outcome-stat-${i}`}>
              <p
                className="text-3xl md:text-4xl leading-none mb-2 tabular"
                style={{ fontFamily: "'Fraunces', Georgia, serif", fontWeight: 500, color: INK }}
              >
                {o.stat}
              </p>
              <p className="text-xs md:text-sm text-[var(--nx-fg-graphite)] mb-4 leading-snug max-w-[18ch]">
                {o.label}
              </p>
              <Sparkline points={o.points} color={o.color} />
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}

